{
  "expo": {
    "name": "Comrades",
    "slug": "comrades",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "comrades",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Comrades uses Bluetooth to discover and connect to nearby peers for proximity handshakes.",
        "NSBluetoothPeripheralUsageDescription": "Comrades uses Bluetooth to exchange signed session data with nearby peers.",
        "NSCameraUsageDescription": "Comrades uses the camera to scan QR bootstrap payloads before BLE session authentication."
      },
      "bundleIdentifier": "com.jack.v.curtis.comrades"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.jack.v.curtis.comrades",
      "permissions": [
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_ADVERTISE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Comrades uses secure storage to protect identity keys behind device authentication."
        }
      ],
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": [
            "central",
            "peripheral"
          ],
          "bluetoothAlwaysPermission": "Comrades uses Bluetooth to discover and connect to nearby peers for proximity handshakes."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Comrades uses the camera to scan QR bootstrap payloads before BLE session authentication."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ab236ade-cbb8-4c43-9ac0-b6e3206a0f52"
      }
    },
    "owner": "jack.v.curtis"
  }
}
